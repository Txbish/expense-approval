# Copy to .env.local and fill in. For local dev, run `npx supabase status` and
# use the printed API URL + anon/service_role keys.

# Public — safe in the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only. NEVER prefix with NEXT_PUBLIC. Used by seed/red-team scripts.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional — observability. Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
